// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UnidadeSaude{
  id               String   @id @default(autoincrement())
  cnes             String   @unique
  nome             String
  tipo             String
  turno            String
  endereco         String
  telefone         String?

  observacoes      String?  
  equipes          String? 
  equipamentos     String?

  createdAt        DateTime @default(now())
}